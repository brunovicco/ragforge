APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=ragforge

# Local infra started via `docker compose --profile core --profile search up -d`
# (see docker-compose.yml). Credentials here match that file's dev-only defaults.
DATABASE_URL=postgresql://ragforge:ragforge@localhost:5432/ragforge
OPENSEARCH_URL=http://localhost:9200

# Optional Langfuse tracing (opt-in; see docs/LLM_OBSERVABILITY.md).
# Leave unset to keep tracing disabled. Requires `uv sync --extra tracing`.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_CAPTURE_CONTENT=false

# Required for `make bench-live` and any live run of GoogleGeminiEmbedder,
# GeminiContextualizer, or GeminiSummarizer: gemini-embedding-001 is the
# frozen embedding model (ADR-0005, benchmark-v01.yaml); GeminiContextualizer
# generates per-chunk context for Contextual Retrieval; GeminiSummarizer
# generates per-group summaries for the RAPTOR tree. Not needed for
# `make bench` (cached replay, ADR-0004). Never commit a real value.
# GEMINI_API_KEY=
