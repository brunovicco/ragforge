{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeGitInstructions": true,
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "outputStyle": "Engineering",
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch --show-current)",
      "Bash(uv lock --check)",
      "Bash(uv sync --frozen *)",
      "Bash(uv run python scripts/quality_gate.py *)",
      "Bash(uv run ruff *)",
      "Bash(uv run python scripts/validate_architecture.py)",
      "Bash(uv run python scripts/validate_mcp_config.py)",
      "Bash(uv run mypy *)",
      "Bash(uv run pytest *)",
      "Bash(uv run bandit *)",
      "Bash(uv run pip-audit *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(./.env.test)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git push --force*)",
      "Bash(sudo *)",
      "Bash(terraform destroy*)",
      "Bash(claude mcp add * --header *Bearer*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/session_context.py"
            ],
            "timeout": 10,
            "statusMessage": "Loading safe project context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/protect_sensitive_files.py"
            ],
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/validate_bash.py"
            ],
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_mcp.py"
            ],
            "timeout": 5,
            "statusMessage": "Checking MCP data egress and mutation risk"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/scan_secrets.py"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/format_python.py"
            ],
            "timeout": 60,
            "statusMessage": "Formatting changed Python file"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/scan_worktree.py"
            ],
            "timeout": 30,
            "statusMessage": "Scanning all changed files for secrets"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/statusline.py\"",
    "padding": 1
  },
  "disableBypassPermissionsMode": "disable"
}
