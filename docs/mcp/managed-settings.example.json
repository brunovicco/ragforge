{
  "allowManagedMcpServersOnly": true,
  "allowedMcpServers": [
    {
      "serverUrl": "https://api.githubcopilot.com/*"
    },
    {
      "serverUrl": "https://mcp.engineering.example.com/*"
    },
    {
      "serverCommand": [
        "uvx",
        "--from",
        "company-mcp==1.2.3",
        "company-mcp"
      ]
    }
  ],
  "deniedMcpServers": [
    {
      "serverUrl": "http://*"
    }
  ]
}
